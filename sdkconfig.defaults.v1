# Hardware v1: ESP32 + HI229

# IMU sensor selection
CONFIG_IMU_SENSOR_HI229=y

# Bootloader - OTA rollback
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y

# Flash mode - QIO for performance
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y

# CPU frequency - 240MHz
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y

# BLE controller
CONFIG_BTDM_CTRL_BLE_MAX_CONN=3

# NimBLE flow control
CONFIG_BT_NIMBLE_HS_FLOW_CTRL=y

# FreeRTOS runtime stats
CONFIG_FREERTOS_GENERATE_RUN_TIME_STATS=y

# LWIP - increased UDP PCBs
CONFIG_LWIP_MAX_UDP_PCBS=512

# Wi-Fi SoftAP
CONFIG_ESP_WIFI_SOFTAP_SUPPORT=y

# PHY
CONFIG_ESP_PHY_REDUCE_TX_POWER=y

# IRAM optimization - reduce IRAM usage for ESP32
CONFIG_ESP_WIFI_IRAM_OPT=n
CONFIG_ESP_WIFI_RX_IRAM_OPT=n
